# ─── Frontend Environment Variables ───────────────────────────
# Copy file này thành .env.local và điền giá trị phù hợp

# Backend Gateway URL
# - Local:  http://localhost:8000
# - VPS:    http://<IP_VPS>:8000  (ví dụ: http://84.247.147.180:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google Sign-In client id used by the frontend login page.
# This must match GOOGLE_CLIENT_ID in the auth service; otherwise
# /api/auth/google will return "Invalid Google token".
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
